# Copy this file to .env and fill in real values before starting the stack.
# Never commit .env to version control.

# Postgres
POSTGRES_PASSWORD=

# GlitchTip Django secret (openssl rand -hex 32)
SECRET_KEY=

# SSO proxy session signing secret (openssl rand -hex 32)
SESSION_SECRET=

# Keycloak admin console password
KEYCLOAK_ADMIN_PASSWORD=

# Must match the 'secret' field for the sso-proxy client in keycloak/realm.json
KEYCLOAK_CLIENT_SECRET=sso-proxy-secret

# Full-scope GlitchTip API token used by the proxy (set by glitchtip-init.py at startup)
GLITCHTIP_PROXY_TOKEN=

# GlitchTip Django superuser (created by glitchtip-init.py)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=
